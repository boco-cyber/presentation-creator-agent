# AI Provider — choose one: ollama | groq | openrouter | lmstudio | none
AI_PROVIDER=none

# Ollama (local, free — install from ollama.com)
OLLAMA_MODEL=llama3.2

# Groq (free tier — get key at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# OpenRouter (free models — get key at openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# LM Studio (local, free)
LMSTUDIO_MODEL=local-model

# Generic (used when AI_PROVIDER is set, overrides above)
AI_API_KEY=

# App
NEXT_PUBLIC_APP_NAME=Presentation Creator Agent
